{
  "manifest_version": 3,
  "name": "Make arXiv Red Again",
  "version": "1.0.0",
  "description": "Restores arXiv's iconic red banner, reverting the 2026 black header redesign.",
  "browser_specific_settings": {
    "gecko": {
      "id": "make-arxiv-red-again@noahfarr.com",
      "strict_min_version": "109.0"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://arxiv.org/*",
        "*://*.arxiv.org/*"
      ],
      "css": ["arxiv-red.css"],
      "run_at": "document_start"
    }
  ]
}
